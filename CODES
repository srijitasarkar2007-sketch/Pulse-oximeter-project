void loop()
{
  Blynk.run();

  if (mySerial.available())
  {
    String data = mySerial.readStringUntil('\n');

    int bpmIndex = data.indexOf("BPM:");
    int spo2Index = data.indexOf("SpO2:");

    if (bpmIndex >= 0 && spo2Index >= 0)
    {
      bpm = data.substring(bpmIndex + 4, data.indexOf(",", bpmIndex)).toInt();
      spo2 = data.substring(spo2Index + 5).toInt();

      Serial.print("BPM: ");
      Serial.println(bpm);
      Serial.print("SpO2: ");
      Serial.println(spo2);

      Blynk.virtualWrite(V0, bpm);
      Blynk.virtualWrite(V1, spo2);
    }
  }
}

